# ─────────────────────────────────────────────────────────
# trigads Proton — Environment Variable Template
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and NEVER committed.
# ─────────────────────────────────────────────────────────

# ── Meta WhatsApp Cloud API ───────────────────────────────
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WABA_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ── Firebase (Firestore + Auth) ───────────────────────────
# These NEXT_PUBLIC_ vars are exposed to the browser (required by Firebase JS SDK)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# ── Next Auth ─────────────────────────────────────────────
AUTH_SECRET=""
# Local dev:  AUTH_URL="http://localhost:3000"
# Production: AUTH_URL="https://proton.trigads.com"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true